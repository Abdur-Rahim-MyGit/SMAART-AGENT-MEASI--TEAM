# ─────────────────────────────────────────────────────────────────────────────
# SMAART Career Intelligence Platform — Backend Environment Variables
# Copy this file to backend/.env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

PORT=5000

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_long_random_secret_string_min_32_chars

# ── MongoDB ─────────────────────────────────────────────────────────────────────
# Option A: Local MongoDB (run `mongod` first)
MONGO_URI=mongodb://127.0.0.1:27017/smaart_db
# Option B: MongoDB Atlas  
# MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/smaart_db

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
# Option A: Local PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=smaart_db
PG_USER=postgres
PG_PASSWORD=your_postgres_password
# Option B: Cloud (Railway / Render / Supabase) — overrides individual vars above
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ── AI Service (Build Phase Only) ───────────────────────────────────────────────
# Only needed when running admin AI data generation (quarterly). NOT needed for runtime.
OPENROUTER_API_KEY=sk-or-...
AI_MODEL=anthropic/claude-3.5-sonnet

# ── Admin Bootstrap ─────────────────────────────────────────────────────────────
# Used for the one-time /api/admin/bootstrap endpoint that promotes a user to ADMIN
# Change this to a secret value before deployment
BOOTSTRAP_SECRET=smaart-bootstrap-2026
